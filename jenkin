pipeline {
    agent any

    environment {
        IMAGE_NAME = "haravinashivaprasad1/maven-exam"
    }

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/haravinashivaprasad1-afk/mavanproject', branch: 'master'
            }
        }

        stage('Build Maven Project') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    dockerImage = docker.build("${IMAGE_NAME}:latest")
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'node') {
                        dockerImage.push('latest')
                    }
                }
            }
        }
    }

    post {
        always {
            deleteDir()
        }
    }
}
